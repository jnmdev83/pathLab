# Database connection string (e.g. postgresql://postgres:postgres@localhost:5432/choosemylab)
DATABASE_URL=postgresql://username:password@localhost:5432/dbname
PORT=5000
NODE_ENV=development

# REAL EMAIL CONFIGURATION (Required to send real OTPs and Welcome Emails)
# 1. Use a Gmail address
# 2. Go to Google Account -> Security -> 2-Step Verification -> App Passwords
# 3. Create a new App Password and paste it below (it is a 16-character code without spaces)
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_16_digit_app_password

# Secure Google Identity Sign-In Configuration
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
